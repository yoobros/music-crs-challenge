# Copy to `.env` and fill in the values below.
# Everything not listed here works with built-in defaults
# (embeddings: local Ollama `qwen3-embedding:0.6b` at http://localhost:11434).

# ----- Response LLM (OpenAI-compatible chat API) ----------------------------
# Required for response generation (Stage 1 full run). Example: z.ai GLM-5.2.
# Any OpenAI-compatible chat endpoint/model can be substituted.
MYMODULE_CHAT_PROVIDER=openai
MYMODULE_LLM_OPENAI_URL=https://api.z.ai/api/paas/v4
MYMODULE_LLM_OPENAI_MODEL=glm-5.2
MYMODULE_LLM_OPENAI_API_KEY=
# GLM-5.2 is a reasoning model; keep this >= 3000 or responses get truncated.
MYMODULE_LLM_MAX_TOKENS=32768

# ----- Two-tower search ------------------------------------------------------
# The bundle ships prebuilt ANN indexes; ANN search matches the submitted run.
MYMODULE_TWOTOWER_ANN=1
